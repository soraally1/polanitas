rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────────────────────

    /** Returns true if the request comes from an authenticated user. */
    function isAuth() {
      return request.auth != null;
    }

    /** Returns true if the authenticated user's UID matches the given uid. */
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    /** Validates that incoming data only contains allowed fields (no extra fields injected). */
    function hasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }


    // ── /users/{uid} ──────────────────────────────────────────────────────────
    //
    // Stores the user's profile, accessibility prefs, and platform selections.
    // Only the owner can read and write their own document.
    //
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && hasOnly([
                         'name', 'age', 'gender', 'platforms',
                         'accessibility', 'profileCompleted'
                       ]);
      allow update: if isOwner(uid)
                    && hasOnly([
                         'name', 'age', 'gender', 'platforms',
                         'accessibility', 'profileCompleted'
                       ]);
      allow delete: if false; // Never allow client-side deletion of profiles

      // ── /users/{uid}/moduleProgress/{moduleId} ──────────────────────────
      // Quiz answers and lesson completion — owned by the user only.
      match /moduleProgress/{moduleId} {
        allow read, write: if isOwner(uid);
      }
    }


    // ── /sessions/{sessionId} ─────────────────────────────────────────────────
    //
    // Each session belongs to a specific user (stored in session.userId).
    // - Read/List: only the owner (userId field must match auth.uid).
    // - Create: only authenticated users; userId must match their own UID.
    // - Update: only the owner; cannot change the userId or createdAt field.
    // - Delete: not allowed from the client.
    //
    match /sessions/{sessionId} {
      // Single-document read: owner only (or server-side unauthenticated reads from Server Actions)
      allow read:   if isAuth() && resource.data.userId == request.auth.uid || !isAuth();
      // Collection list/query: enforce userId filter on the server too
      allow list:   if isAuth() && resource.data.userId == request.auth.uid;
      // Create: authenticated client OR unauthenticated Server Action
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'topic', 'createdAt'])
                    || !isAuth();
      // Update: authenticated owner OR unauthenticated Server Action
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.createdAt == resource.data.createdAt
                    || !isAuth();
      allow delete: if false;

      // ── /sessions/{sessionId}/research/output ──────────────────────────────
      //
      // Researcher agent output. Written by server actions / AI agents.
      // Client can only read if they own the parent session.
      //
      match /research/output {
        allow read:   if isAuth() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        // Allow server-side writes (Server Actions use unauthenticated Client SDK)
        allow write:  if true;
      }


      // ── /sessions/{sessionId}/strategy/output ─────────────────────────────
      //
      // Strategist agent output. Same rules as research output.
      //
      match /strategy/output {
        allow read:   if isAuth() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        // Allow server-side writes (Server Actions use unauthenticated Client SDK)
        allow write:  if true;
      }


      // ── /sessions/{sessionId}/analytics/{docId} ───────────────────────────
      //
      // Eye-tracking / heatmap analytics reports. Multiple documents per session.
      // Clients can read and CREATE their own analytics (eye-tracking data sent from browser).
      // Update/delete is not allowed from the client.
      //
      match /analytics/{reportId} {
        allow read:   if isAuth() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        // Allow server-side writes and authenticated client writes (eye-tracking data)
        allow create: if true;
        allow update: if false;
        allow delete: if false;
      }

      // Allow analysis output written by server actions
      match /analysis/output {
        allow read:   if isAuth() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow write:  if true;
      }
    }


    // ── Fallback: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
